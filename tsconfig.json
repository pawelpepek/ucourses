{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "vitest/globals"
    ],
    "baseUrl": ".",
    "paths": {
      "@hooks/*": [
        "src/hooks/*"
      ],
      "@models": [
        "src/models/index"
      ],
      "@models/*": [
        "src/models/*"
      ],
      "@store/*": [
        "src/store/*"
      ],
      "@shared/*": [
        "src/components/shared/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}